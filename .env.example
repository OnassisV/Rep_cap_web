## Genera esta clave en tu maquina o en Railway. Ejemplo:
## python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=replace-with-a-real-secret-key

## Para publicacion en Railway debe ir en 0.
DJANGO_DEBUG=0

## Hosts web permitidos. El dominio sale de Railway en Settings > Domains.
## Mientras no tengas dominio final, puedes dejar el subdominio generico de Railway.
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,testserver,.up.railway.app

## Mismos dominios del sitio web, pero con esquema http/https.
## Cuando Railway te asigne el dominio final, agregalo aqui como https://tu-dominio.
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,https://*.up.railway.app

# URL principal de MySQL en Railway. Si esta definida, Django, LEGACY_DB y AULA_DB
# pueden reutilizarla sin declarar host/usuario/password por separado.
## Sacala de Railway en el servicio MySQL > Connect > MySQL URL.
RAILWAY_MYSQL_URL=mysql://usuario:password@host:puerto/base

# Opcional: define explicitamente la base principal de Django si no quieres usar
# la misma URL compartida de Railway.
## Si decides llenarlas, salen de la misma RAILWAY_MYSQL_URL:
## - HOST: host
## - NAME: nombre de la base
## - USER: usuario
## - PASSWORD: password
## - PORT: puerto
DJANGO_DB_HOST=
DJANGO_DB_NAME=
DJANGO_DB_USER=
DJANGO_DB_PASSWORD=
DJANGO_DB_PORT=3306

# Opcional: override para tablas legacy si no usan la misma base compartida.
## Si todas las tablas ya estan en la misma base de Railway, dejalas vacias.
DIFOCA_DB_LOCAL_HOST=
DIFOCA_DB_LOCAL_USER=
DIFOCA_DB_LOCAL_PASSWORD=
DIFOCA_DB_LOCAL_NAME=
DIFOCA_DB_LOCAL_PORT=3306

# Opcional: override para tablas de Aula Virtual si no usan la misma base compartida.
## Si Aula Virtual tambien ya fue importada a la misma base de Railway, dejalas vacias.
DIFOCA_DB_AULA_HOST=
DIFOCA_DB_AULA_USER=
DIFOCA_DB_AULA_PASSWORD=
DIFOCA_DB_AULA_NAME=
DIFOCA_DB_AULA_PORT=3306

## Recomendado para publicacion detras del proxy HTTPS de Railway.
DJANGO_SECURE_SSL_REDIRECT=1
DJANGO_SESSION_COOKIE_SECURE=1
DJANGO_CSRF_COOKIE_SECURE=1
DJANGO_SECURE_HSTS_SECONDS=3600
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=1
DJANGO_SECURE_HSTS_PRELOAD=0

DIFOCA_MAX_LOGIN_ATTEMPTS=5
DIFOCA_LOGIN_LOCKOUT_MINUTES=10
DIFOCA_LOCKOUT_FAILURE_TTL_MINUTES=60

## Opcional: barra de estado de actualizacion horaria en la web.
## Ventana esperada: cada hora desde las 07:10 hasta las 19:10.
DIFOCA_SYNC_STATUS_KEY=railway_hourly_sync
DIFOCA_SYNC_START_HOUR=7
DIFOCA_SYNC_END_HOUR=19
DIFOCA_SYNC_MINUTE=10
